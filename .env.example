# ---------------------------------------------------------------
# INDFACTORY · RRHH
# Copia este archivo como .env.local y llena los valores.
# NINGUNA de estas variables lleva prefijo NEXT_PUBLIC_: todas son
# server-only. La service_role NUNCA debe llegar al navegador.
# ---------------------------------------------------------------

# Supabase (proyecto mandarina-DATA, schema rrhh)
SUPABASE_URL=https://piingkecjgoisnxccvaa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Secreto para firmar la cookie de sesion.
# Genera uno con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Nombre que se muestra en la app
NEXT_PUBLIC_EMPRESA=INDFACTORY
